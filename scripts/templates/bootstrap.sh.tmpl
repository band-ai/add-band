#!/usr/bin/env bash
#
# Bootstrap a Band <-> @@NAME@@ connection.
#
# Fetches the official `@@SKILL_NAME@@` setup skill from the @@NAME@@ Band plugin
# repo and runs it end to end. The skill is the source of truth: it @@SUMMARY@@.
# This script only delivers the skill to the box and hands off — the real logic
# lives upstream.
#
# Source of truth: @@REPO@@
# Skill:           @@SKILL@@
#
# Credentials (set one before running):
#   export @@CRED_ENV@@=...            # auto-registers an agent, then removed
#   # — or bring a pre-created agent from app.band.ai/agents/new —
#   export BAND_AGENT_ID=...  BAND_API_KEY=...
#
set -euo pipefail

REPO="${BAND_@@NAME_UPPER@@_REPO:-@@REPO@@}"
REF="${BAND_@@NAME_UPPER@@_REF:-@@REF@@}"   # defaults to @@REF@@; pin a tag/commit for a reproducible install
SKILL_REL="@@SKILL@@"

err() { printf '\033[31m%s\033[0m\n' "$*" >&2; }
log() { printf '\033[36m→ %s\033[0m\n' "$*"; }

command -v git >/dev/null    || { err "git is required."; exit 1; }
command -v @@HARNESS_BIN@@ >/dev/null || {
  err "@@NAME@@ is not on PATH. Install @@NAME@@ first, then re-run this on the gateway host."
  exit 1
}

# If the plugin is already installed, the skill is available natively — just run it.
if @@INSTALLED_CHECK@@; then
  log "@@NAME@@ plugin already installed — running: @@RUN@@"
  exec @@RUN@@
fi

workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT

log "Fetching the @@SKILL_NAME@@ skill from ${REPO}${REF:+@$REF}…"
if [ -n "$REF" ]; then
  git clone --depth 1 --branch "$REF" "$REPO" "$workdir" >/dev/null 2>&1
else
  git clone --depth 1 "$REPO" "$workdir" >/dev/null 2>&1
fi

skill="$workdir/$SKILL_REL"
[ -f "$skill" ] || { err "Skill not found at $SKILL_REL in $REPO."; exit 1; }

# Fresh box: the plugin (and thus the skill) isn't installed yet. The skill does
# the install too — hand it to a shell-capable agent on THIS host to follow.
log "Plugin not installed yet. The setup skill (it installs the plugin itself) follows:"
echo
cat "$skill"
cat <<EOF

────────────────────────────────────────────────────────────────────────
Next: have a shell-capable agent on THIS host follow the skill above.
  • @@NAME@@ is the natural choice — feed it the skill and let it run the Procedure.
  • For any other agent, use the one-shot prompt at
      ${REPO}/blob/${REF:-HEAD}/docs/INSTALL-PROMPT.md
@@PREREQ_NOTE@@
────────────────────────────────────────────────────────────────────────
EOF
